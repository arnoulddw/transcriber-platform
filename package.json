{
  "name": "transcriber-platform",
  "version": "1.0.0",
  "description": "Self-hosted AI transcription platform for teams with RBAC, admin analytics, public API, and reusable LLM workflows.",
  "main": "index.js",
  "scripts": {
    "build:css:dev": "tailwindcss -i ./app/static/css/tailwind_input.css -o ./app/static/css/tailwind_output.css --watch",
    "build:css:prod": "tailwindcss -i ./app/static/css/tailwind_input.css -o ./app/static/css/tailwind_output.css --minify"
  },
  "keywords": [
    "transcription",
    "audio-transcription",
    "speech-to-text",
    "self-hosted",
    "whisper",
    "openai",
    "assemblyai",
    "speaker-diarization",
    "rbac",
    "audio",
    "flask",
    "tailwind"
  ],
  "author": "Arnould de Wasseige",
  "license": "MIT",
  "devDependencies": {
    "@headlessui/tailwindcss": "^0.2.1",
    "@tailwindcss/forms": "^0.5.7",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3"
  }
}
